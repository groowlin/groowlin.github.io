{
  "site": "portfolio",
  "contentSource": "mdx",
  "designSystem": {
    "fontFamily": "Inter",
    "letterSpacing": "0.03em",
    "shapeSystem": {
      "style": "ios-like corner smoothing",
      "appliesTo": "all non-pill rounded surfaces",
      "preserveRadiusTokens": true,
      "pillSurfacesUseSmoothing": false,
      "presets": {
        "default": "regular",
        "work": "subtle",
        "preview": "strong",
        "topCard": "strong",
        "avatar": "strong",
        "activeBubble": "strong"
      }
    },
    "rhythm": {
      "titleSubtitle": {
        "top": 60,
        "bottom": 40
      },
      "caseSectionHeadings": {
        "top": 60,
        "bottom": 40
      }
    }
  },
  "pages": [
    {
      "page": "home",
      "path": "/",
      "legacy": false,
      "sections": [
        {
          "name": "top-card-to-profile",
          "components": [
            "top-card",
            "top-card-avatar",
            "top-card-title",
            "top-card-subtitle",
            "top-card-icons",
            "top-card-arrow"
          ]
        },
        {
          "name": "home-header",
          "components": [
            "home-title",
            "home-subtitle"
          ]
        },
        {
          "name": "work-showcase-sections-body-driven",
          "components": [
            "optional-section-title",
            "case-item",
            "case-item-label",
            "case-item-meta",
            "glass-highlight-layer"
          ]
        },
        {
          "name": "hover-preview",
          "components": [
            "preview-pane",
            "preview-media"
          ]
        }
      ]
    },
    {
      "page": "work-detail",
      "path": "/work/[slug]",
      "legacy": false,
      "sections": [
        {
          "name": "top-card-to-home",
          "components": [
            "top-card",
            "top-card-avatar",
            "top-card-title",
            "top-card-subtitle",
            "top-card-icons",
            "top-card-arrow"
          ]
        },
        {
          "name": "page-header",
          "components": [
            "work-title",
            "work-subtitle"
          ]
        },
        {
          "name": "work-mdx-content",
          "components": [
            "markdown-blocks",
            "mdx-media",
            "mdx-cta"
          ]
        }
      ]
    },
    {
      "page": "about",
      "path": "/about",
      "legacy": false,
      "sections": [
        {
          "name": "top-card-to-home",
          "components": [
            "top-card",
            "top-card-avatar",
            "top-card-title",
            "top-card-subtitle",
            "top-card-icons",
            "top-card-arrow"
          ]
        },
        {
          "name": "profile-mdx-content",
          "components": [
            "markdown-blocks"
          ]
        }
      ]
    }
  ]
}
