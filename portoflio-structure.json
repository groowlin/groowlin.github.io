{
  "site": "portfolio",
  "contentSource": "mdx",
  "pages": [
    {
      "page": "home",
      "path": "/",
      "legacy": false,
      "sections": [
        {
          "name": "profile-navigation-card",
          "components": ["avatar", "profile-name", "about-link", "contact-icons", "profile-arrow"]
        },
        {
          "name": "work-showcase-sections",
          "components": ["section-title", "case-item", "case-item-label", "case-item-meta", "glass-highlight-layer"]
        },
        {
          "name": "hover-preview",
          "components": ["preview-pane", "preview-media"]
        }
      ]
    },
    {
      "page": "work-detail",
      "path": "/work/[slug]",
      "legacy": false,
      "sections": [
        {
          "name": "page-header",
          "components": ["work-title", "work-subtitle"]
        },
        {
          "name": "work-mdx-content",
          "components": ["markdown-blocks", "mdx-media", "mdx-cta"]
        }
      ]
    },
    {
      "page": "about",
      "path": "/about",
      "legacy": false,
      "sections": [
        {
          "name": "page-header",
          "components": ["title"]
        },
        {
          "name": "about-mdx-content",
          "components": ["markdown-blocks"]
        }
      ]
    },
    {
      "page": "connect",
      "path": "/connect",
      "legacy": false,
      "sections": [
        {
          "name": "page-header",
          "components": ["title"]
        },
        {
          "name": "connect-mdx-content",
          "components": ["markdown-blocks"]
        }
      ]
    }
  ]
}
